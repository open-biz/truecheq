# =============================================================================
# TruCheq - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# World ID - Seller Verification
# -----------------------------------------------------------------------------
# Get your App ID from: https://developer.worldcoin.org/
# Create an app, then use the App ID (starts with app_...)
NEXT_PUBLIC_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RP_ID=rp_xxxxxxxxxxxxxxxx

# World ID environment — 'production' for mainnet, 'staging' for testnet.
# IMPORTANT: Your app_id must match this environment (staging app_id with staging,
# production app_id with production). Get the correct app_id from developer.world.org.
NEXT_PUBLIC_WLD_ENV=production

# -----------------------------------------------------------------------------
# Smart Contract - Base Mainnet
# -----------------------------------------------------------------------------
# Address of deployed TruCheqRegistry.sol contract
# Run: bun x hardhat run scripts/deploy.js --network base
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Coinbase x402 - Payment Receiver
# -----------------------------------------------------------------------------
# Wallet address that will receive x402 payments (your deployer wallet)
NEXT_PUBLIC_X402_PAY_TO=0x0000000000000000000000000000000000000000

# CDP credentials for x402 mainnet facilitator (verify + settle payments)
# Generate from: https://portal.cdp.coinbase.com/
# Required for production; not needed for testnet (base-sepolia)
CDP_API_KEY_NAME=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CDP_API_KEY_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nyour-key-here\n-----END EC PRIVATE KEY-----

# XMTP environment — defaults to 'production' (mainnet).
# Set to 'dev' for local development/testing on testnet.
NEXT_PUBLIC_XMTP_ENV=production

# -----------------------------------------------------------------------------
# XMTP - System Relay (Server-side notifications)
# -----------------------------------------------------------------------------
# The system relay sends welcome messages and payment confirmations
# to ANY buyer or seller — fully multi-tenant. This is NOT a specific seller.
# Generate a new wallet and derive its address, then register on XMTP.
XMTP_SYSTEM_PRIVATE_KEY=0x_your_system_private_key
XMTP_SYSTEM_ADDRESS=0x_your_derived_system_address

# -----------------------------------------------------------------------------
# XMTP - Demo Seller (for demo listings only)
# -----------------------------------------------------------------------------
# Optional: Override the demo seller address shown in seed listings.
# If not set, falls back to the hardcoded demo address.
# NEXT_PUBLIC_DEMO_SELLER_ADDRESS=0x_your_demo_seller_address

# -----------------------------------------------------------------------------
# World ID - Server-side RP Signing
# -----------------------------------------------------------------------------
# Private key for signing World ID verification requests
# Generate via: https://developer.worldcoin.org/
WORLD_PRIVATE_KEY=0x_your_world_id_4_private_key
RP_SIGNING_KEY=0x_your_world_id_4_private_key

# -----------------------------------------------------------------------------
# Filebase - IPFS Storage
# -----------------------------------------------------------------------------
# Get credentials from: https://filebase.com/
FILEBASE_ACCESS_KEY=your_filebase_access_key
FILEBASE_SECRET_KEY=your_filebase_secret_key

# Bucket name you created in Filebase
NEXT_PUBLIC_FILEBASE_BUCKET=trucheq

# Your custom gateway (e.g., yourname.myfilebase.com)
NEXT_PUBLIC_FILEBASE_GATEWAY=yourname.myfilebase.com

# -----------------------------------------------------------------------------
# Hardhat - Contract Deployment (DO NOT COMMIT)
# -----------------------------------------------------------------------------
# Mnemonic for deployment - use a dedicated deployer wallet
# DO NOT use your main wallet or commit this!
MNEMONIC=your twelve word mnemonic phrase here

# Optional: Base Mainnet RPC URL (wagmi will use default if not set)
# NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org